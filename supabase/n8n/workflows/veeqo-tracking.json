{
  "name": "Sync: Veeqo Tracking",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 2
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [180, 300],
      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "Schedule Every 2h"
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "shipments",
        "returnAll": false,
        "limit": 2000,
        "filters": {
          "conditions": [
            {
              "keyName": "data_source",
              "condition": "eq",
              "keyValue": "veeqo"
            }
          ]
        },
        "options": {
          "returnFields": ["id", "external_ids", "status", "tracking_number"],
          "sortByUi": {
            "sortByValues": [
              {
                "key": "created_at",
                "order": "desc"
              }
            ]
          }
        }
      },
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [420, 300],
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
      "name": "Fetch Veeqo Shipments",
      "credentials": {
        "supabaseApi": {
          "id": "gHruXnC2qqFwxMPZ",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst valid = items.filter(item => {\n  const ext = item.json.external_ids;\n  return ext && ext.veeqo;\n});\nconsole.log(`Filtered: ${valid.length}/${items.length} shipments have veeqo allocation IDs`);\nreturn valid;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Filter Valid Shipments"
    },
    {
      "parameters": {
        "batchSize": 50,
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [900, 300],
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Batch 50 Shipments"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1140, 140],
      "id": "a1b2c3d4-0013-4000-8000-000000000013",
      "name": "All Batches Done"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn items.map(item => ({\n  json: {\n    shipment_id: item.json.id,\n    current_status: item.json.status,\n    tracking_number: item.json.tracking_number,\n    allocation_id: String(item.json.external_ids.veeqo)\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 300],
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Extract Allocation ID"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.veeqo.com/shipping/tracking_events/{{ $json.allocation_id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1380, 300],
      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Veeqo Get Tracking Events",
      "credentials": {
        "httpHeaderAuth": {
          "id": "3HIHmn9LaxU03JrD",
          "name": "Veeqo API"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Merge HTTP responses with original shipment data, map statuses\nconst VEEQO_TO_DB_STATUS = {\n  'awaiting_collection': 'awaiting_collection',\n  'collected': 'in_transit',\n  'in_transit': 'in_transit',\n  'out_for_delivery': 'out_for_delivery',\n  'delivered': 'delivered',\n  'attempted_delivery': 'attempted_delivery',\n  'returned_to_sender': 'returned_to_sender',\n  'cancelled': 'cancelled',\n  'exception': 'exception'\n};\n\nconst STATUS_PRIORITY = {\n  'created': 0, 'label_printed': 1, 'awaiting_collection': 2,\n  'in_transit': 3, 'out_for_delivery': 4, 'delivered': 5,\n  'attempted_delivery': 4, 'returned_to_sender': 5,\n  'cancelled': 5, 'exception': 4\n};\n\nconst responses = $input.all();\nconst originals = $('Extract Allocation ID').all();\n\nconst eventRows = [];\nconst statusUpdates = [];\nlet withEvents = 0;\n\nfor (let i = 0; i < responses.length; i++) {\n  const resp = responses[i].json;\n  const orig = originals[i]?.json;\n  if (!orig) continue;\n\n  const { shipment_id, current_status, tracking_number, allocation_id } = orig;\n\n  // Parse events from response (skip errors/404s)\n  let events = [];\n  if (Array.isArray(resp)) {\n    events = resp;\n  } else if (resp && typeof resp === 'object' && !resp.statusCode && !resp.error) {\n    if (resp.status && resp.timestamp) events = [resp];\n  }\n  if (events.length === 0) continue;\n  withEvents++;\n\n  // Build tracking_events rows\n  for (const e of events) {\n    eventRows.push({\n      shipment_id,\n      tracking_number: tracking_number || `veeqo-${allocation_id}`,\n      status: e.status || 'unknown',\n      description: e.description || null,\n      location: e.location || null,\n      occurred_at: e.timestamp,\n      raw_data: e\n    });\n  }\n\n  // Check if shipment status needs updating\n  const latestEvent = events[events.length - 1];\n  const newStatus = VEEQO_TO_DB_STATUS[latestEvent.status];\n  if (newStatus && newStatus !== current_status) {\n    const currentPri = STATUS_PRIORITY[current_status] || 0;\n    const newPri = STATUS_PRIORITY[newStatus] || 0;\n    if (newPri >= currentPri) {\n      const update = { shipment_id, status: newStatus };\n      if (newStatus === 'delivered' && latestEvent.timestamp) {\n        update.delivered_at = latestEvent.timestamp;\n      }\n      statusUpdates.push(update);\n    }\n  }\n}\n\nconsole.log(`Batch: ${withEvents}/${responses.length} with events, ${eventRows.length} rows, ${statusUpdates.length} updates`);\nreturn [{ json: { eventRows, statusUpdates } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1620, 300],
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Map Events & Status"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/tracking_events",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Prefer",
              "value": "return=minimal,resolution=merge-duplicates"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.eventRows) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1860, 300],
      "id": "a1b2c3d4-0008-4000-8000-000000000008",
      "name": "Upsert Tracking Events",
      "credentials": {
        "supabaseApi": {
          "id": "gHruXnC2qqFwxMPZ",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Emit individual items for each shipment status update\nconst data = $('Map Events & Status').first().json;\nconst updates = data.statusUpdates || [];\nif (updates.length === 0) {\n  return [{ json: { _noUpdates: true } }];\n}\nreturn updates.map(u => ({ json: u }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2100, 300],
      "id": "a1b2c3d4-0009-4000-8000-000000000009",
      "name": "Emit Status Updates"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-skip",
              "leftValue": "={{ $json._noUpdates }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2340, 300],
      "id": "a1b2c3d4-0010-4000-8000-000000000010",
      "name": "Has Status Updates?"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/shipments?id=eq.{{ $json.shipment_id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify((() => { const d = {...$json}; delete d.shipment_id; return d; })()) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2580, 200],
      "id": "a1b2c3d4-0011-4000-8000-000000000011",
      "name": "PATCH Shipment Status",
      "credentials": {
        "supabaseApi": {
          "id": "gHruXnC2qqFwxMPZ",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Rate limit pause: 50 Veeqo requests per batch, limit is 140/min\n// Wait ~25s between batches to stay safely under the limit\nawait new Promise(r => setTimeout(r, 25000));\nconsole.log('Rate limit pause complete, next batch');\nreturn [{ json: { delayed: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2820, 300],
      "id": "a1b2c3d4-0012-4000-8000-000000000012",
      "name": "Rate Limit Delay 25s"
    }
  ],
  "connections": {
    "Schedule Every 2h": {
      "main": [
        [
          {
            "node": "Fetch Veeqo Shipments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Veeqo Shipments": {
      "main": [
        [
          {
