            "index": 0
          }
        ]
      ]
    },
    "Filter Valid Shipments": {
      "main": [
        [
          {
            "node": "Batch 50 Shipments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Batch 50 Shipments": {
      "main": [
        [
          {
            "node": "All Batches Done",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Extract Allocation ID",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Allocation ID": {
      "main": [
        [
          {
            "node": "Veeqo Get Tracking Events",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Veeqo Get Tracking Events": {
      "main": [
        [
          {
            "node": "Map Events & Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Map Events & Status": {
      "main": [
        [
          {
            "node": "Upsert Tracking Events",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Upsert Tracking Events": {
      "main": [
        [
          {
            "node": "Emit Status Updates",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Emit Status Updates": {
      "main": [
        [
          {
            "node": "Has Status Updates?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has Status Updates?": {
      "main": [
        [
          {
            "node": "PATCH Shipment Status",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Rate Limit Delay 25s",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "PATCH Shipment Status": {
      "main": [
        [
          {
            "node": "Rate Limit Delay 25s",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Rate Limit Delay 25s": {
      "main": [
        [
          {
            "node": "Batch 50 Shipments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
