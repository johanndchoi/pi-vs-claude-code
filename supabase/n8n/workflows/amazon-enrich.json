{
  "name": "Sync: Amazon Enrich",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [180, 300],
      "id": "a1000001-0001-4000-8000-000000000001",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/sync_cursors",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "job_name", "value": "eq.amazon-enrich" },
            { "name": "select", "value": "*" },
            { "name": "limit", "value": "1" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [400, 300],
      "id": "a1000001-0002-4000-8000-000000000002",
      "name": "Load Cursor",
      "credentials": {
        "supabaseApi": { "id": "gHruXnC2qqFwxMPZ", "name": "Supabase account" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract cursor state or set defaults\nconst cursorRows = $input.all();\nconst cursor = (Array.isArray(cursorRows[0]?.json) && cursorRows[0].json.length > 0)\n  ? cursorRows[0].json[0]\n  : (cursorRows[0]?.json?.id ? cursorRows[0].json : null);\n\nconst lastOrderedAt = cursor?.cursor_data?.last_ordered_at || null;\n\nreturn [{\n  json: {\n    lastOrderedAt,\n    cursorExists: !!cursor,\n    cursorData: cursor?.cursor_data || {}\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [620, 300],
      "id": "a1000001-0003-4000-8000-000000000003",
      "name": "Parse Cursor"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/orders",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "channel_id", "value": "eq.7f84462f-86c8-4e09-abb6-285631db0d83" },
            { "name": "tax_amount", "value": "eq.0" },
            { "name": "select", "value": "id,order_number,ordered_at,tax_amount,external_ids" },
            { "name": "order", "value": "ordered_at.desc" },
            { "name": "limit", "value": "200" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Prefer", "value": "count=exact" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [840, 300],
      "id": "a1000001-0004-4000-8000-000000000004",
      "name": "Fetch Pending Orders",
      "credentials": {
        "supabaseApi": { "id": "gHruXnC2qqFwxMPZ", "name": "Supabase account" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filter orders older than cursor if applicable, and skip already-checked\nconst orders = $input.all().map(i => i.json);\nconst cursorData = $('Parse Cursor').first().json;\nconst lastOrderedAt = cursorData.lastOrderedAt;\n\nlet filtered = orders;\nif (lastOrderedAt) {\n  filtered = orders.filter(o => o.ordered_at < lastOrderedAt);\n}\n\n// Skip orders that have already been tax_checked\nfiltered = filtered.filter(o => {\n  const ext = o.external_ids || {};\n  return !ext.tax_checked;\n});\n\n// Cap at 100 per run to stay within n8n execution limits\nconst batch = filtered.slice(0, 100);\n\nif (batch.length === 0) {\n  return [{ json: { empty: true, message: 'No orders to process' } }];\n}\n\nreturn batch.map(o => ({ json: o }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 300],
      "id": "a1000001-0005-4000-8000-000000000005",
      "name": "Filter and Batch Orders"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-empty",
              "leftValue": "={{ $json.empty }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "notTrue" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1280, 300],
      "id": "a1000001-0006-4000-8000-000000000006",
      "name": "Has Orders?"
    },
    {
      "parameters": {
        "options": { "reset": false },
        "loopCount": "={{ $input.all().length }}"
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1500, 200],
      "id": "a1000001-0007-4000-8000-000000000007",
      "name": "Loop Orders"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.amazon.com/auth/o2/token",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpCustomAuth",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "grant_type", "value": "refresh_token" },
            { "name": "refresh_token", "value": "={{ $credentials.json.refreshToken }}" },
            { "name": "client_id", "value": "={{ $credentials.json.clientId }}" },
            { "name": "client_secret", "value": "={{ $credentials.json.clientSecret }}" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [1720, 200],
      "id": "a1000001-0008-4000-8000-000000000008",
      "name": "Amazon LWA Token",
      "credentials": {
        "httpCustomAuth": { "id": "Ok0qiTbXLIzVMHjV", "name": "Amazon SP-API" }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://sellingpartnerapi-na.amazon.com/orders/v0/orders/{{ $('Loop Orders').item.json.order_number }}/orderItems",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-amz-access-token", "value": "={{ $('Amazon LWA Token').item.json.access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } },
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [1940, 200],
      "id": "a1000001-0009-4000-8000-000000000009",
      "name": "SP-API GetOrderItems",
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "// Calculate tax from SP-API order items response\nconst spApiResult = $input.first().json;\nconst orderItems = spApiResult?.payload?.OrderItems || [];\nconst order = $('Loop Orders').item.json;\n\nlet totalTax = 0;\nconst lineItems = [];\n\nfor (const item of orderItems) {\n  const itemTax = parseFloat(item.ItemTax?.Amount || '0');\n  const shippingTax = parseFloat(item.ShippingTax?.Amount || '0');\n  const lineTax = itemTax + shippingTax;\n  totalTax += lineTax;\n  lineItems.push({\n    asin: item.ASIN,\n    sku: item.SellerSKU,\n    quantity: item.QuantityOrdered,\n    item_tax: itemTax,\n    shipping_tax: shippingTax,\n    total_tax: +lineTax.toFixed(2)\n  });\n}\n\nconst hasError = !!spApiResult?.errors;\n\nreturn [{\n  json: {\n    orderId: order.id,\n    orderNumber: order.order_number,\n    orderedAt: order.ordered_at,\n    existingExternalIds: order.external_ids || {},\n    spApiTax: +totalTax.toFixed(2),\n    lineItems,\n    needsShipStationFallback: totalTax === 0 && !hasError,\n    spApiError: hasError\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2160, 200],
      "id": "a1000001-0010-4000-8000-000000000010",
      "name": "Calculate SP-API Tax"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-needs-ss",
              "leftValue": "={{ $json.needsShipStationFallback }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2380, 200],
      "id": "a1000001-0011-4000-8000-000000000011",
      "name": "Needs ShipStation?"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://ssapi.shipstation.com/orders?orderNumber={{ encodeURIComponent($json.orderNumber) }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBasicAuth",
        "options": {
          "response": { "response": { "responseFormat": "json" } },
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [2600, 100],
      "id": "a1000001-0012-4000-8000-000000000012",
      "name": "ShipStation Get Tax",
      "credentials": {
        "httpBasicAuth": { "id": "HMaOhjiiZTgoiHb5", "name": "ShipStation" }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "// Extract tax from ShipStation response\nconst ssResult = $input.first().json;\nconst prevData = $('Calculate SP-API Tax').first().json;\nconst ssOrders = ssResult?.orders || [];\n\nlet ssTax = 0;\nfor (const order of ssOrders) {\n  ssTax += order.taxAmount || 0;\n}\nssTax = +ssTax.toFixed(2);\n\nconst finalTax = ssTax;\nconst source = ssTax > 0 ? 'shipstation' : null;\n\nreturn [{\n  json: {\n    ...prevData,\n    finalTax,\n    taxSource: source,\n    spApiTax: 0\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2820, 100],
      "id": "a1000001-0013-4000-8000-000000000013",
      "name": "Parse SS Tax"
    },
    {
      "parameters": {
        "jsCode": "// SP-API had tax > 0, prepare final result\nconst data = $('Calculate SP-API Tax').first().json;\n\nreturn [{\n  json: {\n    ...data,\n    finalTax: data.spApiTax,\n    taxSource: 'sp-api'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2600, 300],
      "id": "a1000001-0014-4000-8000-000000000014",
      "name": "SP-API Has Tax"
    },
    {
      "parameters": {
        "jsCode": "// Merge results from both branches and build Supabase update payload\nconst data = $input.first().json;\nconst existingExtIds = data.existingExternalIds || {};\n\nif (data.finalTax > 0) {\n  // Has tax - update order\n  return [{\n    json: {\n      orderId: data.orderId,\n      orderNumber: data.orderNumber,\n      orderedAt: data.orderedAt,\n      hasTax: true,\n      updatePayload: {\n        tax_amount: data.finalTax,\n        external_ids: {\n          ...existingExtIds,\n          tax_source: data.taxSource,\n          ...(data.lineItems && data.lineItems.length ? { amazon_tax_details: data.lineItems } : {})\n        }\n      }\n    }\n  }];\n} else {\n  // No tax found - mark as checked\n  return [{\n    json: {\n      orderId: data.orderId,\n      orderNumber: data.orderNumber,\n      orderedAt: data.orderedAt,\n      hasTax: false,\n      updatePayload: {\n        external_ids: {\n          ...existingExtIds,\n          tax_checked: new Date().toISOString()\n        }\n      }\n    }\n  }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3040, 200],
      "id": "a1000001-0015-4000-8000-000000000015",
      "name": "Build Update Payload"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/orders?id=eq.{{ $json.orderId }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.updatePayload) }}",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [3260, 200],
      "id": "a1000001-0016-4000-8000-000000000016",
      "name": "Update Order in Supabase",
      "credentials": {
        "supabaseApi": { "id": "gHruXnC2qqFwxMPZ", "name": "Supabase account" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Add a 1.5s delay for SP-API rate limiting (0.5 req/s burst 30)\nawait new Promise(r => setTimeout(r, 1500));\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3480, 200],
      "id": "a1000001-0017-4000-8000-000000000017",
      "name": "Rate Limit Delay"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/sync_cursors",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "resolution=merge-duplicates,return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ job_name: 'amazon-enrich', cursor_data: { last_ordered_at: $json.orderedAt, last_order_number: $json.orderNumber, updated_at: new Date().toISOString() }, updated_at: new Date().toISOString() }) }}",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [3700, 200],
      "id": "a1000001-0018-4000-8000-000000000018",
      "name": "Save Cursor",
      "credentials": {
        "supabaseApi": { "id": "gHruXnC2qqFwxMPZ", "name": "Supabase account" }
      }
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1500, 500],
      "id": "a1000001-0019-4000-8000-000000000019",
      "name": "No Orders - Done"
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[{ "node": "Load Cursor", "type": "main", "index": 0 }]]
    },
    "Load Cursor": {
      "main": [[{ "node": "Parse Cursor", "type": "main", "index": 0 }]]
    },
    "Parse Cursor": {
      "main": [[{ "node": "Fetch Pending Orders", "type": "main", "index": 0 }]]
    },
    "Fetch Pending Orders": {
      "main": [[{ "node": "Filter and Batch Orders", "type": "main", "index": 0 }]]
    },
    "Filter and Batch Orders": {
      "main": [[{ "node": "Has Orders?", "type": "main", "index": 0 }]]
    },
    "Has Orders?": {
      "main": [
        [{ "node": "Loop Orders", "type": "main", "index": 0 }],
        [{ "node": "No Orders - Done", "type": "main", "index": 0 }]
      ]
    },
    "Loop Orders": {
      "main": [
        [{ "node": "Save Cursor", "type": "main", "index": 0 }],
        [{ "node": "Amazon LWA Token", "type": "main", "index": 0 }]
      ]
    },
    "Amazon LWA Token": {
      "main": [[{ "node": "SP-API GetOrderItems", "type": "main", "index": 0 }]]
    },
    "SP-API GetOrderItems": {
      "main": [[{ "node": "Calculate SP-API Tax", "type": "main", "index": 0 }]]
    },
    "Calculate SP-API Tax": {
      "main": [[{ "node": "Needs ShipStation?", "type": "main", "index": 0 }]]
    },
    "Needs ShipStation?": {
      "main": [
        [{ "node": "ShipStation Get Tax", "type": "main", "index": 0 }],
        [{ "node": "SP-API Has Tax", "type": "main", "index": 0 }]
      ]
    },
    "ShipStation Get Tax": {
      "main": [[{ "node": "Parse SS Tax", "type": "main", "index": 0 }]]
    },
    "Parse SS Tax": {
      "main": [[{ "node": "Build Update Payload", "type": "main", "index": 0 }]]
    },
    "SP-API Has Tax": {
      "main": [[{ "node": "Build Update Payload", "type": "main", "index": 0 }]]
    },
