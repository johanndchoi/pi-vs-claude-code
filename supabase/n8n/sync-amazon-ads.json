dDate: dateInfo.endDate\n  }\n}));"}, "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1280, 300], "id": "a1000001-0001-4000-8000-000000000006", "name": "Code: Select Profile & Prepare Dates", "credentials": {"httpCustomAuth": {"id": "Ok0qiTbXLIzVMHjV", "name": "Amazon SP-API Credentials"}}}, {"parameters": {"batchSize": 1, "options": {}}, "type": "n8n-nodes-base.splitInBatches", "typeVersion": 3, "position": [1500, 300], "id": "a1000001-0001-4000-8000-000000000007", "name": "Loop Over Dates"}, {"parameters": {"method": "POST", "url": "https://advertising-api.amazon.com/v2/sp/campaigns/report", "sendHeaders": true, "headerParameters": {"parameters": [{"name": "Authorization", "value": "=Bearer {{ $json.accessToken }}"}, {"name": "Amazon-Advertising-API-ClientId", "value": "={{ $('HTTP: LWA Token').first().json.client_id || '' }}"}, {"name": "Amazon-Advertising-API-Scope", "value": "={{ $json.profileId }}"}, {"name": "Content-Type", "value": "application/json"}]}, "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify({ reportDate: $json.reportDate, metrics: 'campaignName,campaignId,impressions,clicks,cost,campaignStatus' }) }}", "options": {"response": {"response": {"responseFormat": "json"}}}}, "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1720, 300], "id": "a1000001-0001-4000-8000-000000000008", "name": "HTTP: Request SP Report", "credentials": {"httpCustomAuth": {"id": "Ok0qiTbXLIzVMHjV", "name": "Amazon SP-API Credentials"}}}, {"parameters": {"jsCode": "// Prepare polling context: carry forward report ID and auth info\nconst reportData = $json;\nconst dateItem = $('Loop Over Dates').first().json;\n\nreturn [{\n  json: {\n    reportId: reportData.reportId,\n    reportStatus: reportData.status || 'IN_PROGRESS',\n    profileId: dateItem.profileId,\n    accessToken: dateItem.accessToken,\n    reportDate: dateItem.reportDate,\n    endDate: dateItem.endDate,\n    pollCount: 0\n  }\n}];"}, "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1940, 300], "id": "a1000001-0001-4000-8000-000000000009", "name": "Code: Prepare Poll Context"}, {"parameters": {"amount": 15, "unit": "seconds"}, "type": "n8n-nodes-base.wait", "typeVersion": 1.1, "position": [2160, 300], "id": "a1000001-0001-4000-8000-000000000010", "name": "Wait 15s", "webhookId": "amazon-ads-poll-wait"}, {"parameters": {"method": "GET", "url": "=https://advertising-api.amazon.com/v2/reports/{{ $json.reportId }}", "sendHeaders": true, "headerParameters": {"parameters": [{"name": "Authorization", "value": "=Bearer {{ $json.accessToken }}"}, {"name": "Amazon-Advertising-API-ClientId", "value": ""}, {"name": "Amazon-Advertising-API-Scope", "value": "={{ $json.profileId }}"}]}, "options": {"response": {"response": {"responseFormat": "json"}}}}, "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [2380, 300], "id": "a1000001-0001-4000-8000-000000000011", "name": "HTTP: Poll Report Status", "credentials": {"httpCustomAuth": {"id": "Ok0qiTbXLIzVMHjV", "name": "Amazon SP-API Credentials"}}}, {"parameters": {"jsCode": "// Merge poll result with context and increment poll count\nconst pollResult = $json;\nconst prevContext = $('Wait 15s').first().json || $('Code: Prepare Poll Context').first().json;\n\nreturn [{\n  json: {\n    ...prevContext,\n    reportStatus: pollResult.status,\n    downloadUrl: pollResult.location || null,\n    statusDetails: pollResult.statusDetails || null,\n    pollCount: (prevContext.pollCount || 0) + 1\n  }\n}];"}, "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2600, 300], "id": "a1000001-0001-4000-8000-000000000012", "name": "Code: Merge Poll Result"}, {"parameters": {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "poll-success", "leftValue": "={{ $json.reportStatus }}", "rightValue": "SUCCESS", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}}, "type": "n8n-nod