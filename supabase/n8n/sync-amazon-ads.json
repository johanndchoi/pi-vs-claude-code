cy_code: 'USD',\n    incurred_at: `${reportDate.slice(0, 4)}-${reportDate.slice(4, 6)}-${reportDate.slice(6, 8)}T00:00:00Z`,\n    external_ref: `ads-sp-${c.campaignId}-${reportDate}`,\n    metadata: {\n      campaign_id: c.campaignId,\n      campaign_name: c.campaignName,\n      campaign_status: c.campaignStatus,\n      impressions: c.impressions,\n      clicks: c.clicks,\n      cost: c.cost,\n      profile_id: profileId,\n      report_date: reportDate\n    }\n  }));\n\nif (feeRows.length === 0) {\n  return [{ json: { skipped: true, reportDate, message: 'No campaigns with spend' } }];\n}\n\nreturn [{ json: { feeRows, reportDate, count: feeRows.length } }];"}, "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [3260, 300], "id": "a1000001-0001-4000-8000-000000000016", "name": "Code: Transform Campaigns"}, {"parameters": {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "has-rows", "leftValue": "={{ $json.skipped }}", "rightValue": true, "operator": {"type": "boolean", "operation": "notTrue"}}], "combinator": "and"}}, "type": "n8n-nodes-base.if", "typeVersion": 2, "position": [3480, 300], "id": "a1000001-0001-4000-8000-000000000017", "name": "IF: Has Fee Rows?"}, {"parameters": {"method": "POST", "url": "https://skgzcllomhsmpbkdnqqc.supabase.co/rest/v1/channel_fees?on_conflict=external_ref", "sendHeaders": true, "headerParameters": {"parameters": [{"name": "Prefer", "value": "resolution=merge-duplicates,return=minimal"}, {"name": "Content-Type", "value": "application/json"}]}, "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.feeRows) }}", "options": {"response": {"response": {"responseFormat": "text"}}}}, "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [3700, 200], "id": "a1000001-0001-4000-8000-000000000018", "name": "HTTP: Upsert Ad Spend", "credentials": {"supabaseApi": {"id": "gHruXnC2qqFwxMPZ", "name": "Supabase account"}}}, {"paramet