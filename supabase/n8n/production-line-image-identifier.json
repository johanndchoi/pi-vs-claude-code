    {
      "parameters": {
        "jsCode": "// Normalize shipment result + build photo record payload\nconst items = $input.all();\nconst raw = items[0]?.json || {};\nconst shipment = raw.id ? raw : null;\n\nconst trackingNumber = $(\"Rename to Tracking Number\").item.json.name ||\n                       $(\"Extract Tracking Number\").item.json.trackingNumber || \"\";\n\nconst matched = !!shipment;\nconst folder = matched ? \"matched\" : \"unmatched\";\nconst ts = new Date().toISOString().replace(/[:.]/g, \"-\").slice(0, 19);\nconst ext = $(\"Download file\").item.binary?.data?.fileExtension || \"jpg\";\nconst storagePath = folder + \"/\" + trackingNumber + \"/\" + ts + \".\" + ext;\n\nconst ocrRaw = $(\"Extract Tracking Number\").item.json.ocrRaw || \"\";\nconst ocrConfidence = $(\"Extract Tracking Number\").item.json.ocrConfidence || 0;\nconst driveFileId = $(\"Download file\").item.json.id || \"\";\n// Parse fileSize: n8n gives \"317 kB\" not raw bytes\nconst fileSizeRaw = $(\"Download file\").item.binary?.data?.fileSize || \"0\";\nconst fileSizeParsed = (() => {\n    const s = String(fileSizeRaw).trim();\n    const m = s.match(/^([\\d.]+)\\s*(kB|MB|GB|bytes?)?$/i);\n    if (!m) return parseInt(s) || 0;\n    const num = parseFloat(m[1]);\n    const unit = (m[2] || \"\").toLowerCase();\n    if (unit === \"kb\") return Math.round(num * 1024);\n    if (unit === \"mb\") return Math.round(num * 1024 * 1024);\n    if (unit === \"gb\") return Math.round(num * 1024 * 1024 * 1024);\n    return Math.round(num);\n})();\nconst fileSize = fileSizeParsed;\nconst mimeType = $(\"Download file\").item.binary?.data?.mimeType || \"image/jpeg\";\n\n// Pass through binary from Download file so Upload can send it\nconst binaryData = $(\"Download file\").item.binary || {};\n\nreturn [{\n    json: {\n        matched,\n        shipment_id: shipment ? shipment.id : null,\n        tracking_number: trackingNumber,\n        carrier_name: shipment ? shipment.carrier_name : null,\n        order_id: shipment ? shipment.order_id : null,\n        storage_path: storagePath,\n        upload_url: \"https://skgzcllomhsmpbkdnqqc.supabase.co/storage/v1/object/shipment-photos/\" + storagePath,\n        photo_record: {\n            shipment_id: shipment ? shipment.id : null,\n            tracking_number: trackingNumber,\n            storage_path: storagePath,\n            ocr_raw: ocrRaw,\n            ocr_confidence: ocrConfidence,\n            drive_file_id: driveFileId,\n            file_size_bytes: fileSize,\n            mime_type: mimeType,\n            matched: matched,\n            match_method: matched ? \"exact\" : null\n        }    },\n    binary: binaryData\n}];"
      },
