      "name": "Tesseract"
    },
    {
      "parameters": {
        "jsCode": "// Extract tracking number from Tesseract OCR output\n// The Tesseract node outputs the raw OCR text — we just need to find the tracking number\n\nreturn items.map((item) => {\n    // Tesseract node output: text is in item.json.text or item.json.data or item.json\n    const ocrText = item.json?.text || item.json?.data?.text || item.json?.recognizedText || JSON.stringify(item.json) || '';\n    const confidence = item.json?.confidence || item.json?.data?.confidence || 0;\n\n    // --- Extract tracking numbers using carrier patterns ---\n    const patterns = [\n        // UPS: 1Z + 6 alphanumeric + 10 digits (18 chars)\n        // Handles OCR errors: I→1, 2→Z for first two chars\n        { carrier: 'UPS', re: /[1Il][Z2][0-9A-Z]{6}[0-9]{10}/gi, fix: s => '1Z' + s.slice(2).toUpperCase() },\n\n        // USPS: 20-34 digits starting with 9\n        { carrier: 'USPS', re: /9[0-9]{19,33}/g, fix: s => s },\n\n        // FedEx: 12 or 15 digits\n        { carrier: 'FedEx', re: /\\b[0-9]{12}\\b/g, fix: s => s },\n        { carrier: 'FedEx', re: /\\b[0-9]{15}\\b/g, fix: s => s },\n\n        // OnTrac: C or D + 14-19 digits\n        { carrier: 'OnTrac', re: /[CD][0-9]{14,19}/gi, fix: s => s.toUpperCase() },\n\n        // Amazon Logistics: TBA + 10-15 digits\n        { carrier: 'Amazon', re: /TBA[0-9]{10,15}/gi, fix: s => s.toUpperCase() },\n    ];\n\n    // Also try with all spaces/hyphens stripped\n    const stripped = ocrText.replace(/[\\s-]/g, '');\n\n    const found = new Map();\n    for (const { carrier, re, fix } of patterns) {\n        for (const src of [ocrText, stripped]) {\n            const matches = src.match(re) || [];\n            for (const m of matches) {\n                const normalized = fix(m);\n                if (!found.has(normalized)) {\n                    found.set(normalized, carrier);\n                }\n            }\n        }\n    }\n\n    // Pick the best tracking number (prefer UPS/USPS/FedEx over others)\n    const priority = ['UPS', 'USPS', 'FedEx', 'OnTrac', 'Amazon'];\n    let trackingNumber = '';\n    for (const carrier of priority) {\n        for (const [tn, c] of found) {\n            if (c === carrier) { trackingNumber = tn; break; }\n        }\n        if (trackingNumber) break;\n    }\n\n    // Fallback: look for \"tracking\" keyword nearby\n    if (!trackingNumber) {\n        const m = ocrText.match(/tracking\\s*(?:number|#|no)?\\s*:?\\s*([A-Z0-9]{10,35})/i);\n        if (m) trackingNumber = m[1].replace(/[^A-Z0-9]/gi, '');\n    }\n\n    return {\n        json: {\n            trackingNumber,\n            ocrRaw: ocrText.trim(),\n            ocrConfidence: confidence,\n            allTracking: Object.fromEntries(found),\n        },\n    };\n});\n"
      },
