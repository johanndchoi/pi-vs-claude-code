# ─────────────────────────────────────────────
#  Skills — credentials resolved via 1Password
#  Usage: op run --env-file .env.skills -- pi
# ─────────────────────────────────────────────

# Linear
LINEAR_API_KEY=op://Agents Service Accounts/Linear OpenClaw API Credentials/credential

# Todoist
TODOIST_API_TOKEN=op://Agents Service Accounts/Todoist API Credential/credential

# Airtable (shipment-tracker)
AIRTABLE_API_KEY=op://Agents Service Accounts/Airtable API Credentials/credential

# Veeqo (shipment-tracker)
VEEQO_API_KEY=op://Agents Service Accounts/Veeqo API Credentials/credential

# Amazon SP-API
SP_API_CLIENT_ID=op://Agents Service Accounts/Amazon SP-API Credentials/LWACredentials
SP_API_CLIENT_SECRET=op://Agents Service Accounts/Amazon SP-API Credentials/ClientSecret
SP_API_REFRESH_TOKEN=op://Agents Service Accounts/Amazon SP-API Credentials/SellerRefreshToken
SP_API_MARKETPLACE_ID=op://Agents Service Accounts/Amazon SP-API Credentials/MarketplaceId
